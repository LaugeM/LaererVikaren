<Page
    x:Class="LaererVikaren.Views.Pages.FindMatchingSubstitutePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LaererVikaren.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="FindMatchingSubstitutePage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Height="53"
            Margin="0,10,0,0"
            Padding="8"
            VerticalAlignment="Top"
            Background="#00AC58">
            <Border.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="White" />
                </Style>
                <Style TargetType="Button">
                    <Setter Property="Foreground" Value="White" />
                </Style>
            </Border.Resources>


            <StackPanel Orientation="Horizontal">

                <StackPanel Margin="0,0,6,0" Orientation="Horizontal">


                    <!--  DatePicker with local watermark style  -->
                    <DatePicker
                        x:Name="LessonDatePicker"
                        Width="auto"
                        Height="auto"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="White"
                        Focusable="False"
                        IsTabStop="False"
                        SelectedDate="{Binding LessonDate, Mode=TwoWay}">

                        <DatePicker.Resources>
                            <Style TargetType="{x:Type DatePickerTextBox}">
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                            <Grid>
                                                <ScrollViewer
                                                    x:Name="PART_ContentHost"
                                                    HorizontalScrollBarVisibility="Hidden"
                                                    VerticalScrollBarVisibility="Hidden" />
                                                <TextBlock
                                                    x:Name="PART_Watermark"
                                                    Margin="3,0,0,0"
                                                    Focusable="False"
                                                    Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                    IsHitTestVisible="False"
                                                    Text="Vælg en dato"
                                                    Visibility="Collapsed" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter TargetName="PART_Watermark" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                                <Trigger Property="Text" Value="{x:Null}">
                                                    <Setter TargetName="PART_Watermark" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter TargetName="PART_Watermark" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="PART_Watermark" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DatePicker.Resources>

                    </DatePicker>
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Text="Tidsrum" />
                    <TextBox
                        x:Name="TimeframeTextBox"
                        Width="auto"
                        AcceptsReturn="True"
                        Text="{Binding Timeframe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </StackPanel>


                <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Text="Fag" />
                    <TextBox
                        x:Name="SubjectTextBox"
                        Width="120"
                        AcceptsReturn="True"
                        Text="{Binding Subject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" Orientation="Vertical">
                    <Button
                        x:Name="SearchButton"
                        Width="90"
                        Margin="0,0,0,5"
                        Command="{Binding Path=FindMatchingSubstitute}"
                        CommandParameter="{Binding}"
                        Content="Søg" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ListBox
            x:Name="SubstituteListBox"
            Grid.Row="1"
            Margin="0,8,0,0"
            ItemsSource="{Binding SubstituteVM}"
            SelectedItem="{Binding CurrentEntity, UpdateSourceTrigger=PropertyChanged}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4" Orientation="Horizontal">
                        <TextBlock Width="110" Text="{Binding FirstName}" />
                        <TextBlock Width="110" Text="{Binding LastName}" />
                        <TextBlock Width="110" Text="{Binding PhoneNumber}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
